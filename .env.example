# ============================================================================
# AI Employee Configuration Template
# ============================================================================
# Copy this file to .env and customize for your environment:
#   cp .env.example .env
# ============================================================================

# ============================================================================
# Application Settings
# ============================================================================

# Path to Obsidian vault (default: ./vault)
VAULT_PATH=./vault

# Interval in seconds between timeout checks (default: 60, range: 10-3600)
CHECK_INTERVAL=60

# Watcher Enable Flags
# Set to true to enable, false to disable
ENABLE_FILESYSTEM_WATCHER=true  # Watches Inbox/Drop/ for new files
ENABLE_GMAIL_WATCHER=false  # Watches Gmail for new messages (requires credentials)

# ============================================================================
# Gmail Watcher Settings (Optional)
# ============================================================================

# How often to check Gmail for new messages in seconds (default: 120, range: 60-600)
GMAIL_WATCHER_CHECK_INTERVAL=120

# Gmail search query for filtering messages (default: is:unread is:important)
# Examples:
#   "is:unread is:important" - Unread + Important messages
#   "is:unread from:boss@company.com" - Unread from specific sender
#   "is:unread subject:invoice" - Unread with "invoice" in subject
GMAIL_WATCHER_QUERY=is:unread is:important

# Path to Gmail API credentials JSON file (default: vault/credentials.json)
# GMAIL_CREDENTIALS_PATH=vault/credentials.json
# GMAIL_CREDENTIALS_PATH=C:\path\to\credentials.json

# Safe mode: If True, prevent real actions (default: True)
DRY_RUN=true

# Development mode: If True, enable console output and dev features (default: True)
DEV_MODE=true

# ============================================================================
# Claude Code Settings
# ============================================================================

# Claude model to use (default: claude-3-5-sonnet)
# Options: claude-3-5-sonnet, claude-3-opus, claude-3-sonnet, claude-3-haiku
CLAUDE_MODEL=claude-3-5-sonnet

# Timeout in seconds for Claude Code operations (default: 300, range: 30-600)
CLAUDE_TIMEOUT=300

# ============================================================================
# Logging Settings
# ============================================================================

# Enable detailed per-task log files (default: true)
# Set to false to disable task-level logging
LOGS_PER_TASK_ENABLED=true

# Minimum log level to log (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# - DEBUG: Log everything (very verbose, for development)
# - INFO: Log normal operations (balanced)
# - WARNING: Log only warnings and above (production)
# - ERROR: Log only errors (minimal logging)
# - CRITICAL: Log only critical errors (almost silent)
MIN_LOG_LEVEL=INFO

# Note: Logs directory is automatically set to {VAULT_PATH}/Logs
# No need to configure it separately

# ============================================================================
# Email Settings (Optional - for Gmail watcher)
# ============================================================================

# Gmail address for Gmail watcher (optional)
GMAIL_ADDRESS=your.email@gmail.com

# Gmail app password (required if using Gmail watcher)
# Get this from: Google Account > Security > App passwords
GMAIL_APP_PASSWORD=your-app-password-here

# ============================================================================
# Security Best Practices
# ============================================================================
# - Never commit .env file to version control (it's in .gitignore)
# - Use strong passwords for production deployments
# - Rotate app passwords regularly
# - Use separate credentials for development and production
# - Store production secrets in a secure vault or secrets manager
# ============================================================================
